{
  "name": "sbos-a1-erp",
  "version": "0.1.0",
  "private": true,
  "description": "SBOS-A1-ERP — Armenian SME ERP foundation (Node.js + ESM, strict, test-driven).",
  "type": "module",
  "bin": {
    "sbos-server": "bin/sbos-server.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test --test-concurrency=4 --test-timeout=60000",
    "test:unit": "node --test --test-concurrency=4 --test-timeout=60000",
    "smoke:deploy": "bash scripts/deploy-smoke.sh",
    "backup": "bash scripts/backup-sbos.sh",
    "token:print": "bash scripts/print-admin-token.sh",
    "serve": "node bin/sbos-server.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:baseline": "node scripts/lint-baseline.mjs create",
    "lint:check-new": "node scripts/lint-baseline.mjs check",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "node scripts/typecheck-if-typescript.mjs",
    "boundary-check": "node scripts/check-open-core-boundary-contract.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run boundary-check",
    "build": "tsc"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  },
  "dependencies": {
    "express": "^4.21.0"
  }
}
