{
  "name": "sbos-a1-erp",
  "version": "0.1.0",
  "private": true,
  "description": "SBOS-A1-ERP — Armenian SME ERP foundation (Node.js + TypeScript, strict, test-driven).",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test --test-concurrency=4 --test-timeout=60000",
    "test:unit": "node --test --test-concurrency=4 --test-timeout=60000",
    "karpathy:list": "node scripts/karpathy-eval.mjs --list",
    "karpathy:program": "node scripts/karpathy-eval.mjs --program",
    "karpathy:run": "node scripts/karpathy-eval.mjs --run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
